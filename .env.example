# ===== Discord =====
# Bot Token（Discord Developer Portal -> Bot -> Reset Token）
DISCORD_TOKEN=your-discord-bot-token

# ===== LLM 中转站（OpenAI 兼容）=====
# 中转站 / 代理的 base_url，例如 https://your-relay.com/v1
OPENAI_BASE_URL=https://your-relay-station.com/v1
# 中转站分配的 key
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxx
# 模型名（变量名与 bq-bot 对齐；取决于中转站支持，例如 claude-opus-4-8 / gpt-4o-mini）
MODEL_NAME=claude-opus-4-8

# ===== 游戏参数（可选，留空用默认）=====
# 一局总人数（人类 + NPC 补位到这个数），默认 6；想玩 12 人局就设 12
WEREWOLF_TOTAL_PLAYERS=6
# 板子预设：auto（按人数自适应，默认）/ simple / hunter / guard / classic
#   auto    = 狼≈1/3 + 预言家 + 女巫 + 平民（旧行为）
#   simple  = 预言家 + 女巫（不含新角色）
#   hunter  = 预言家 + 女巫 + 猎人
#   guard   = 预言家 + 女巫 + 守卫
#   classic = 预言家 + 女巫 + 猎人 + 守卫（经典 12 人「预女猎守」屠边局，推荐配 12 人）
WEREWOLF_BOARD=auto
# 单个玩家发言/行动的等待秒数，默认 60
WEREWOLF_TURN_SECONDS=60
# NPC 发言温度，默认 0.9
WEREWOLF_NPC_TEMPERATURE=0.9
