# ===== Discord =====
# Bot Token（Discord Developer Portal -> Bot -> Reset Token）
DISCORD_TOKEN=your-discord-bot-token

# ===== LLM 中转站（OpenAI 兼容）=====
# 中转站 / 代理的 base_url，例如 https://your-relay.com/v1
OPENAI_BASE_URL=https://your-relay-station.com/v1
# 中转站分配的 key
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxx
# 模型名（取决于你的中转站支持哪些，例如 gpt-4o-mini / deepseek-chat 等）
OPENAI_MODEL=gpt-4o-mini

# ===== 游戏参数（可选，留空用默认）=====
# 一局总人数（人类 + NPC 补位到这个数），默认 6
WEREWOLF_TOTAL_PLAYERS=6
# 单个玩家发言/行动的等待秒数，默认 60
WEREWOLF_TURN_SECONDS=60
# NPC 发言温度，默认 0.9
WEREWOLF_NPC_TEMPERATURE=0.9
